# SozuPay Dashboard – environment variables
# Copy to .env.local and fill in values. See docs/runbooks.md.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (shared DB with recipient wallet; required for dashboard users)
# NEXT_PUBLIC_SUPABASE_URL=   # project URL from Supabase dashboard
# SUPABASE_SERVICE_ROLE_KEY= # service role key (server only; bypasses RLS)
# DEFAULT_ORG_ID=            # optional: default org UUID so "Mujeres 2000" always shows (avoids name mismatch in prod)
# DEFAULT_ORG_NAME=Mujeres2000   # optional; fallback name if DEFAULT_ORG_ID not set (variants like "Mujeres 2000" are tried)

# Stellar (backend only – never expose secret keys to frontend)
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC (required when org has soroban_contract_id or when using smart accounts)
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# SOROBAN_RPC_URL=https://soroban-mainnet.stellar.org  # for production

# Smart account factory (optional): create C account when user registers G signer
# SMART_ACCOUNT_FACTORY_ID=   # contract id of the factory
# SMART_ACCOUNT_FACTORY_METHOD=create_account   # factory method name
# SMART_ACCOUNT_GET_ADDRESS_VIEW=get_address    # optional: view to get deterministic C address before deploy

# Org disbursement wallet: holds USDC and signs all payout transactions.
# Super-admin authorizes each payout in the app; this wallet signs on Stellar.
# Order of precedence: ORG_DISBURSEMENT_SECRET > STELLAR_DISBURSEMENT_SECRET > STELLAR_FUNDER_SECRET.
# Create a keypair, fund with Friendbot (testnet), add USDC trustline and get test USDC.
ORG_DISBURSEMENT_SECRET=
# STELLAR_DISBURSEMENT_SECRET=
# STELLAR_FUNDER_SECRET=

# Optional: for funding new user Stellar accounts (createAccount)
# STELLAR_FUNDER_SECRET=

# NEXT_PUBLIC_STELLAR_NETWORK=testnet   # optional; for Stellar Expert links
# STELLAR_NETWORK=public
# HORIZON_URL=https://horizon.stellar.org

# Auth
# AUTH_SECRET=  # used to sign session cookie

# Privy (dashboard login: email + optional passkey; simple recovery)
# From https://dashboard.privy.io
# PRIVY_APP_ID=           # app id (server can use this)
# PRIVY_APP_SECRET=       # app secret (optional; for Privy server API calls)
# NEXT_PUBLIC_PRIVY_APP_ID=  # same as PRIVY_APP_ID; required for client (Next.js only exposes NEXT_PUBLIC_* to browser)
# PRIVY_VERIFICATION_KEY= # from Dashboard > App settings > Verification key (for server token verification; not the app secret)

# Mock auth for demo: no login required; one click to dashboard; /dashboard never redirects to login
# AUTH_MOCK=true

# Off-ramp partner (Phase 8 – adapter)
# OFF_RAMP_* as per partner API

# Vault / yield (separate spec – Phase 4)
# VAULT_* as per vault protocol

# Optional: Key derivation / backup (separate security spec)
# KEY_DERIVATION_* – plug-in point per spec §7
